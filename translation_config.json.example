{
  "active_profile": "deepseek-api",
  "profiles": {
    "deepseek-api": {
      "engine": "openai-compatible",
      "model": "deepseek-chat",
      "base_url": "https://api.deepseek.com/v1",
      "api_key_env_var": "DEEPSEEK_API_KEY",
      "strategy": "full_document",
      "temperature": 0.1,
      "timeout": 120.0
    },
    "gemma-local": {
      "engine": "openai-compatible",
      "model": "google/gemma-4-e4b",
      "base_url": "http://127.0.0.1:1234/v1",
      "api_key_env_var": "",
      "strategy": "split_blocks",
      "temperature": 0.1,
      "timeout": 300.0
    }
  }
}

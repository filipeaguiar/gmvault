{
  "active_profile": "deepseek-api",
  "profiles": {
    "deepseek-api": {
      "engine": "openai-compatible",
      "model": "deepseek-chat",
      "base_url": "https://api.deepseek.com/v1",
      "api_key_env_var": "DEEPSEEK_API_KEY",
      "strategy": "full_document",
      "temperature": 0.1,
      "timeout": 120.0
    },
    "qwen-ebserh": {
      "engine": "openai-compatible",
      "model": "qwen-27b",
      "base_url": "https://litellm.ia.hc-ufpe.ebserh/v1",
      "api_key_env_var": "EBSERH_API_KEY",
      "strategy": "full_document",
      "temperature": 0.1,
      "timeout": 300.0
    }
  }
}

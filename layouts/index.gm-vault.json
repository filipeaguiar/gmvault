{{- $categories := slice -}}
{{- $campaigns := slice -}}
{{- range site.Pages -}}
  {{- if eq (partial "helpers/kind.html" .) "campaign" -}}
    {{- $campaigns = $campaigns | append . -}}
  {{- end -}}
{{- end -}}
{{- range (sort $campaigns "Weight") -}}
  {{- $campaignCategories := partial "helpers/gmvault_campaign_categories.html" . -}}
  {{- range $campaignCategories -}}
    {{- $categories = $categories | append . -}}
  {{- end -}}
{{- end -}}
{{- dict "categories" $categories | jsonify (dict "indent" "  ") -}}

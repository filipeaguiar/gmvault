{{- $categories := slice -}}

{{/* 1. Coletar as Campanhas */}}
{{- $campaigns := where site.Pages "Params.kind" "campaign" -}}

{{- range $campaigns -}}
  {{- $campaignPage := . -}}
  {{- $campaignDir := .File.Dir -}}
  
  {{/* --- MÓDULO 1: AVENTURAS --- */}}
  {{- $adventureItems := slice -}}
  
  {{/* Obter as aventuras desta campanha */}}
  {{- $adventuresPath := printf "/%sadventures" $campaignDir -}}
  {{- $adventuresSection := site.GetPage $adventuresPath -}}
  
  {{- if $adventuresSection -}}
    {{- range $adventuresSection.Sections -}}
      {{- if eq .Params.kind "adventure" -}}
        {{- $adventurePage := . -}}
        {{- $adventureDir := .File.Dir -}}
        {{- $adventureTitle := or .Params.titulo_pt_br .Title -}}
        
        {{/* Obter as sessões desta aventura */}}
        {{- $sessionItems := slice -}}
        {{- $sessionsPath := printf "/%ssessions" $adventureDir -}}
        {{- $sessionsSection := site.GetPage $sessionsPath -}}
        
        {{- if $sessionsSection -}}
          {{- range $sessionsSection.Sections -}}
            {{- if eq .Params.kind "session" -}}
              {{- $sessionPage := . -}}
              {{- $sessionDir := .File.Dir -}}
              {{- $sessionTitle := or .Params.titulo_pt_br .Title -}}
              
              {{/* Obter as cenas desta sessão */}}
              {{- $sceneItems := slice -}}
              {{- $scenesPath := printf "/%sscenes" $sessionDir -}}
              {{- $scenesSection := site.GetPage $scenesPath -}}
              
              {{- if $scenesSection -}}
                {{- range $scenesSection.Pages -}}
                  {{- if eq .Params.kind "scene" -}}
                    {{- $scenePage := . -}}
                    {{- $sceneTitle := or .Params.titulo_pt_br .Title -}}
                    
                    {{/* Obter os handouts pertencentes a esta cena */}}
                    {{- $sceneHandouts := slice -}}
                    {{- range .Pages -}}
                      {{- if eq .Params.kind "handout" -}}
                        {{- $visibleToPlayers := false -}}
                        {{- if or (eq .Params.visibility "players") (eq .Params.visibility "public") -}}
                          {{- $visibleToPlayers = true -}}
                        {{- end -}}
                        
                        {{- $handoutItem := dict 
                          "type" "page" 
                          "name" (or .Params.titulo_pt_br .Title) 
                          "id" (printf "page_%s" (substr (.Permalink | md5) 0 8)) 
                          "url" .Permalink 
                        -}}
                        {{- if $visibleToPlayers -}}
                          {{- $handoutItem = merge $handoutItem (dict "visibleToPlayers" true) -}}
                        {{- end -}}
                        
                        {{- $sceneHandouts = $sceneHandouts | append $handoutItem -}}
                      {{- end -}}
                    {{- end -}}
                    
                    {{/* Adicionar a cena */}}
                    {{- $visibleToPlayers := false -}}
                    {{- if or (eq .Params.visibility "players") (eq .Params.visibility "public") -}}
                      {{- $visibleToPlayers = true -}}
                    {{- end -}}
                    
                    {{- $sceneItem := dict 
                      "type" "page" 
                      "name" $sceneTitle 
                      "id" (printf "page_%s" (substr (.Permalink | md5) 0 8)) 
                      "url" .Permalink 
                    -}}
                    {{- if $visibleToPlayers -}}
                      {{- $sceneItem = merge $sceneItem (dict "visibleToPlayers" true) -}}
                    {{- end -}}
                    
                    {{- $sceneItems = $sceneItems | append $sceneItem -}}
                    
                    {{/* Adicionar os handouts da cena */}}
                    {{- range $sceneHandouts -}}
                      {{- $sceneItems = $sceneItems | append . -}}
                    {{- end -}}
                  {{- end -}}
                {{- end -}}
              {{- end -}}
              
              {{/* Adicionar a subcategoria "Cenas da Sessão X" se houver cenas */}}
              {{- if $sceneItems -}}
                {{- $scenesCategory := dict 
                  "type" "category" 
                  "name" (printf "Cenas da %s" $sessionTitle) 
                  "items" $sceneItems 
                  "id" (printf "cat_%s" (substr ( (printf "%s-scenes" .Permalink) | md5) 0 8)) 
                -}}
                
                {{/* Adicionar a sessão antes das cenas */}}
                {{- $visibleToPlayers := false -}}
                {{- if or (eq .Params.visibility "players") (eq .Params.visibility "public") -}}
                  {{- $visibleToPlayers = true -}}
                {{- end -}}
                
                {{- $sessionItem := dict 
                  "type" "page" 
                  "name" $sessionTitle 
                  "id" (printf "page_%s" (substr (.Permalink | md5) 0 8)) 
                  "url" .Permalink 
                -}}
                {{- if $visibleToPlayers -}}
                  {{- $sessionItem = merge $sessionItem (dict "visibleToPlayers" true) -}}
                {{- end -}}
                
                {{- $sessionItems = $sessionItems | append $sessionItem -}}
                {{- $sessionItems = $sessionItems | append $scenesCategory -}}
              {{- end -}}
            {{- end -}}
          {{- end -}}
        {{- end -}}
        
        {{/* Obter os NPCs desta aventura */}}
        {{- $adventureNpcItems := slice -}}
        {{- if .Params.npcs -}}
          {{- range .Params.npcs -}}
            {{- $npcPage := site.GetPage . -}}
            {{- if $npcPage -}}
              {{- $visibleToPlayers := false -}}
              {{- if or (eq $npcPage.Params.visibility "players") (eq $npcPage.Params.visibility "public") -}}
                {{- $visibleToPlayers = true -}}
              {{- end -}}
              
              {{- $npcItem := dict 
                "type" "page" 
                "name" (or $npcPage.Params.titulo_pt_br $npcPage.Title) 
                "id" (printf "page_%s" (substr ($npcPage.Permalink | md5) 0 8)) 
                "url" $npcPage.Permalink 
              -}}
              {{- if $visibleToPlayers -}}
                {{- $npcItem = merge $npcItem (dict "visibleToPlayers" true) -}}
              {{- end -}}
              
              {{- $adventureNpcItems = $adventureNpcItems | append $npcItem -}}
            {{- end -}}
          {{- end -}}
        {{- end -}}
        
        {{/* Adicionar a subcategoria "Sessões de X" se houver sessões */}}
        {{- $adventureSubItems := slice -}}
        {{- if $sessionItems -}}
          {{- $sessionsCategory := dict 
            "type" "category" 
            "name" (printf "Sessões de %s" $adventureTitle) 
            "items" $sessionItems 
            "id" (printf "cat_%s" (substr ( (printf "%s-sessions" .Permalink) | md5) 0 8)) 
          -}}
          {{- $adventureSubItems = $adventureSubItems | append $sessionsCategory -}}
        {{- end -}}
        
        {{/* Adicionar a subcategoria "NPCs de X" se houver NPCs */}}
        {{- if $adventureNpcItems -}}
          {{- $npcsCategory := dict 
            "type" "category" 
            "name" (printf "NPCs de %s" $adventureTitle) 
            "items" $adventureNpcItems 
            "id" (printf "cat_%s" (substr ( (printf "%s-npcs" .Permalink) | md5) 0 8)) 
          -}}
          {{- $adventureSubItems = $adventureSubItems | append $npcsCategory -}}
        {{- end -}}
        
        {{/* Adicionar a aventura principal */}}
        {{- $adventureCategory := dict 
          "type" "category" 
          "name" $adventureTitle 
          "items" $adventureSubItems 
          "id" (printf "cat_%s" (substr (.Permalink | md5) 0 8)) 
        -}}
        {{- $adventureItems = $adventureItems | append $adventureCategory -}}
      {{- end -}}
    {{- end -}}
  {{- end -}}
  
  {{- $adventuresCategory := dict 
    "name" "Aventuras" 
    "items" $adventureItems 
    "id" (printf "cat_%s" (substr ( (printf "%s-adventures-root" .Permalink) | md5) 0 8)) 
  -}}
  {{- $categories = $categories | append $adventuresCategory -}}
  
  {{/* --- MÓDULO 2: CAMPANHA --- */}}
  {{- $campaignItems := slice -}}
  
  {{/* Adicionar a própria página de campanha */}}
  {{- $visibleToPlayers := false -}}
  {{- if or (eq $campaignPage.Params.visibility "players") (eq $campaignPage.Params.visibility "public") -}}
    {{- $visibleToPlayers = true -}}
  {{- end -}}
  {{- $campaignHomeItem := dict 
    "type" "page" 
    "name" (or $campaignPage.Params.titulo_pt_br $campaignPage.Title) 
    "id" (printf "page_%s" (substr ($campaignPage.Permalink | md5) 0 8)) 
    "url" $campaignPage.Permalink 
  -}}
  {{- if $visibleToPlayers -}}
    {{- $campaignHomeItem = merge $campaignHomeItem (dict "visibleToPlayers" true) -}}
  {{- end -}}
  {{- $campaignItems = $campaignItems | append $campaignHomeItem -}}
  
  {{/* Adicionar o Diário (Journal) se existir */}}
  {{- $journalPath := printf "/%sjournal" $campaignDir -}}
  {{- $journalPage := site.GetPage $journalPath -}}
  {{- if $journalPage -}}
    {{- $visibleToPlayers := false -}}
    {{- if or (eq $journalPage.Params.visibility "players") (eq $journalPage.Params.visibility "public") -}}
      {{- $visibleToPlayers = true -}}
    {{- end -}}
    
    {{- $journalItem := dict 
      "type" "page" 
      "name" (or $journalPage.Params.titulo_pt_br $journalPage.Title) 
      "id" (printf "page_%s" (substr ($journalPage.Permalink | md5) 0 8)) 
      "url" $journalPage.Permalink 
    -}}
    {{- if $visibleToPlayers -}}
      {{- $journalItem = merge $journalItem (dict "visibleToPlayers" true) -}}
    {{- end -}}
    
    {{- $campaignItems = $campaignItems | append $journalItem -}}
  {{- end -}}
  
  {{- $campaignCategory := dict 
    "name" "Campanha" 
    "items" $campaignItems 
    "id" (printf "cat_%s" (substr ( (printf "%s-campaign-root" .Permalink) | md5) 0 8)) 
  -}}
  {{- $categories = $categories | append $campaignCategory -}}
{{- end -}}

{{- $finalJson := dict "categories" $categories -}}
{{- $finalJson | jsonify (dict "indent" "  ") -}}
